---
const links = [
  { label: 'work', section: 1 },
  { label: 'stack', section: 2 },
  { label: 'contact', section: 3 }
];
---

<header class="top-bar fixed inset-x-0 top-0 z-50">
  <div class="mx-auto flex h-12 max-w-7xl items-center justify-between px-4 md:h-14 md:px-16">
    <button
      type="button"
      class="nav-jump font-body text-sm"
      data-section="0"
      aria-label="Back to top"
    >
      <span class="text-[var(--color-accent)]">~/</span><span class="hidden sm:inline">abubakar-mahmood</span><span class="sm:hidden">am</span>
    </button>

    <nav class="flex items-center gap-5 md:gap-8" aria-label="Sections">
      {links.map(({ label, section }) => (
        <button
          type="button"
          class="nav-jump font-body text-xs uppercase tracking-caps"
          data-section={section}
        >
          {label}
        </button>
      ))}
      <a
        href="https://github.com/AbubakarMahmood"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden font-body text-xs uppercase tracking-caps text-[var(--color-muted)] transition-colors hover:text-[var(--color-accent)] md:inline"
      >
        github ↗
      </a>
    </nav>
  </div>
</header>
