<script>
  // Type out the hero command unless the visitor prefers reduced motion
  const typed = document.getElementById('typed-cmd');
  const text = typed?.dataset.cmd ?? '';
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (typed && text && !reduced) {
    typed.textContent = '';
    typed.classList.add('type-caret');

    let i = 0;
    const tick = () => {
      typed.textContent = text.slice(0, i + 1);
      i += 1;
      if (i < text.length) {
        setTimeout(tick, 70 + Math.random() * 60);
      } else {
        setTimeout(() => typed.classList.remove('type-caret'), 1600);
      }
    };

    setTimeout(tick, 400);
  }
</script>
