<section id="contact" class="slide-section w-full flex items-center justify-center relative px-6 md:px-16 py-14 md:py-0">
  <div class="max-w-7xl w-full">
    <div class="mb-10 md:mb-16">
      <div class="reveal font-body text-sm text-[var(--color-muted)] mb-4">
        <span class="text-[var(--color-accent)]">$</span> echo "contact"
      </div>
      <h2 class="reveal font-heading text-4xl md:text-7xl mb-4" style="--reveal-delay: 0.08s">LET'S<br/>CONNECT</h2>
    </div>

    <div class="space-y-5 md:space-y-6 max-w-3xl">
      <div class="reveal info-block pl-6" style="--reveal-delay: 0.16s">
        <div class="font-body text-xs text-[var(--color-muted)] mb-2 uppercase tracking-caps">Email</div>
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
          <a
            href="mailto:theabubakar321@gmail.com"
            class="arrow-link font-body text-lg sm:text-xl md:text-3xl safe-link"
          >
            <span class="arrow" aria-hidden="true">→</span> theabubakar321@gmail.com
          </a>
          <button
            type="button"
            id="copy-email"
            data-email="theabubakar321@gmail.com"
            class="font-body text-xs uppercase tracking-caps text-[var(--color-muted)] border border-[var(--color-line)] px-2.5 py-1 transition-colors hover:border-[var(--color-accent-dim)] hover:text-[var(--color-accent)]"
          >
            copy
          </button>
        </div>
      </div>

      <div class="reveal info-block pl-6" style="--reveal-delay: 0.24s">
        <div class="font-body text-xs text-[var(--color-muted)] mb-2 uppercase tracking-caps">GitHub</div>
        <a
          href="https://github.com/AbubakarMahmood"
          target="_blank"
          rel="noopener noreferrer"
          class="arrow-link font-body text-lg sm:text-xl md:text-3xl safe-link"
        >
          <span class="arrow" aria-hidden="true">→</span> github.com/AbubakarMahmood
        </a>
      </div>

      <div class="reveal info-block pl-6" style="--reveal-delay: 0.32s">
        <div class="font-body text-xs text-[var(--color-muted)] mb-2 uppercase tracking-caps">LinkedIn</div>
        <a
          href="https://linkedin.com/in/abubakar-mahmood"
          target="_blank"
          rel="noopener noreferrer"
          class="arrow-link font-body text-lg sm:text-xl md:text-3xl safe-link"
        >
          <span class="arrow" aria-hidden="true">→</span> linkedin.com/in/abubakar-mahmood
        </a>
      </div>
    </div>

    <div class="reveal mt-10 md:mt-16 font-body text-xs text-[var(--color-muted)]" style="--reveal-delay: 0.4s">
      <span class="text-[var(--color-accent)]">$</span> status: <span class="text-[var(--color-text)]">available for opportunities</span>
    </div>

    <footer class="reveal mt-8 border-t border-[var(--color-line)] pt-4 font-body text-xs text-[var(--color-muted)]" style="--reveal-delay: 0.48s">
      © {new Date().getFullYear()} Abubakar Mahmood · built with Astro
    </footer>
  </div>
</section>

<script>
  const copyButton = document.getElementById('copy-email') as HTMLButtonElement | null;

  copyButton?.addEventListener('click', async () => {
    const email = copyButton.dataset.email ?? '';
    try {
      await navigator.clipboard.writeText(email);
      copyButton.textContent = 'copied ✓';
      setTimeout(() => {
        copyButton.textContent = 'copy';
      }, 2000);
    } catch {
      copyButton.textContent = 'ctrl+c?';
      setTimeout(() => {
        copyButton.textContent = 'copy';
      }, 2000);
    }
  });
</script>
