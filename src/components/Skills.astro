---
const skills = [
  { cat: "lang", items: ["Dart", "Python", "TypeScript", "JavaScript", "Java", "SQL"] },
  { cat: "mobile", items: ["Flutter", "Riverpod", "Drift", "SQLite", "Android basics"] },
  { cat: "api", items: ["FastAPI", "REST", "GraphQL", "SQLAlchemy", "JWT", "Celery"] },
  { cat: "quality", items: ["Docker", "GitHub Actions", "pytest", "Playwright", "JUnit", "OpenTelemetry"] }
];
---

<section id="stack" class="slide-section w-full flex items-center justify-center relative px-6 md:px-16 py-14 md:pt-20 md:pb-10">
  <div class="max-w-7xl w-full">
    <div class="mb-8 md:mb-10">
      <div class="reveal font-body text-sm text-[var(--color-muted)] mb-4">
        <span class="text-[var(--color-accent)]">$</span> cat ./stack.txt
      </div>
      <h2 class="reveal font-heading text-4xl md:text-6xl mb-2" style="--reveal-delay: 0.08s">TECHNOLOGY STACK</h2>
    </div>

    <div class="grid grid-cols-2 gap-x-6 gap-y-6 md:gap-x-16 md:gap-y-8">
      {skills.map((category, index) => (
        <div class="reveal info-block pl-3 sm:pl-6" style={`--reveal-delay: ${0.16 + index * 0.08}s`}>
          <div class="font-body text-xs text-[var(--color-accent)] mb-3 uppercase tracking-caps">
            ./{category.cat}
          </div>

          <div class="space-y-1.5">
            {category.items.map((skill) => (
              <div class="skill-item font-body text-xs sm:text-sm font-light flex items-center gap-2">
                <span class="text-[var(--color-muted)]">-</span>
                <span>{skill}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="reveal mt-6 md:mt-8 font-body text-xs text-[var(--color-muted)] border-t border-[var(--color-line)] pt-4" style="--reveal-delay: 0.5s">
      <span class="text-[var(--color-accent)]">info:</span> stack compiled successfully
    </div>
  </div>
</section>
