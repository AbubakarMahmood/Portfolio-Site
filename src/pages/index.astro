---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import SlideNav from '../components/SlideNav.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Abubakar Mahmood - Junior Software Engineer"
  description="Junior Software Engineer in Lahore focused on Flutter, backend APIs, offline-first systems, and practical production-minded software."
>
  <TopBar />
  <SlideNav>
    <main id="slide-scroll" class="slide-scroll app-viewport w-full overflow-y-auto overflow-x-hidden">
      <Hero />
      <Projects />
      <Skills />
      <Contact />
    </main>
  </SlideNav>
</BaseLayout>
